+svc.store.save(tmp);
+const loaded = Store.load(tmp);
+assert.strictEqual(loaded.get(b.id).archived, true);
+fs.writeFileSync(tmp, JSON.stringify({ notes: [{ id: 7, text: "legacy", done: false }], seq: 7 }));
+assert.strictEqual(Store.load(tmp).get(7).archived, false);
+fs.unlinkSync(tmp);
+
+// CLI archive/unarchive/archived commands
+assert.strictEqual(run(["archive", String(a.id)], svc).archived, true);
+assert.ok(run(["archived"], svc).some(n => n.id === a.id));
+assert.strictEqual(run(["unarchive", String(a.id)], svc).archived, false);
+
 console.log("all tests passed");
