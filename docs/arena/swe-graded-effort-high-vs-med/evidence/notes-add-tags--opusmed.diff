diff --git a/src/cli.js b/src/cli.js
index afb0045..ff5766a 100644
--- a/src/cli.js
+++ b/src/cli.js
@@ -1,9 +1,12 @@
-// Tiny CLI: `node src/cli.js add "text"` | `list`.
+// Tiny CLI: `node src/cli.js add "text"` | `list` | `tag <id> <tag>` | `bytag <tag>` | `stats`.
 const { NoteService } = require("./service");
 function run(argv, svc) {
   const [cmd, ...rest] = argv;
   if (cmd === "add") return svc.create(rest.join(" "));
   if (cmd === "list") return svc.pending();
+  if (cmd === "tag") return svc.tag(Number(rest[0]), rest[1]);
+  if (cmd === "bytag") return svc.byTag(rest[0]);
+  if (cmd === "stats") return svc.stats();
   throw new Error("unknown command: " + cmd);
 }
 module.exports = { run };
diff --git a/src/service.js b/src/service.js
index c9c426d..6e89be8 100644
--- a/src/service.js
+++ b/src/service.js
@@ -5,5 +5,9 @@ class NoteService {
   create(text) { if (!text) throw new Error("text required"); return this.store.add(text); }
   complete(id) { const n = this.store.get(id); if (!n) throw new Error("not found"); n.done = true; return n; }
   pending() { return this.store.all().filter(n => !n.done); }
+  tag(id, tag) { if (!this.store.get(id)) throw new Error("not found"); return this.store.addTag(id, tag); }
+  untag(id, tag) { if (!this.store.get(id)) throw new Error("not found"); return this.store.removeTag(id, tag); }
+  byTag(tag) { return this.store.all().filter(n => n.tags.includes(tag)); }
+  stats() { const s = {}; this.store.all().forEach(n => n.tags.forEach(t => { s[t] = (s[t] || 0) + 1; })); return s; }
 }
 module.exports = { NoteService };
diff --git a/src/store.js b/src/store.js
index f0c794e..651a6b4 100644
--- a/src/store.js
+++ b/src/store.js
@@ -2,10 +2,12 @@
 const fs = require("fs");
 class Store {
   constructor() { this.notes = []; this.seq = 0; }
-  add(text) { const n = { id: ++this.seq, text, done: false }; this.notes.push(n); return n; }
+  add(text) { const n = { id: ++this.seq, text, done: false, tags: [] }; this.notes.push(n); return n; }
   get(id) { return this.notes.find(n => n.id === id) || null; }
   all() { return this.notes.slice(); }
+  addTag(id, tag) { const n = this.get(id); if (!n) return null; if (!n.tags.includes(tag)) n.tags.push(tag); return n; }
+  removeTag(id, tag) { const n = this.get(id); if (!n) return null; const i = n.tags.indexOf(tag); if (i !== -1) n.tags.splice(i, 1); return n; }
   save(path) { fs.writeFileSync(path, JSON.stringify({ notes: this.notes, seq: this.seq })); }
-  static load(path) { const s = new Store(); const d = JSON.parse(fs.readFileSync(path, "utf8")); s.notes = d.notes; s.seq = d.seq; return s; }
+  static load(path) { const s = new Store(); const d = JSON.parse(fs.readFileSync(path, "utf8")); s.notes = d.notes.map(n => ({ ...n, tags: n.tags || [] })); s.seq = d.seq; return s; }
 }
 module.exports = { Store };
diff --git a/test/run.js b/test/run.js
index 949ca50..4e30fc3 100644
--- a/test/run.js
+++ b/test/run.js
@@ -1,4 +1,7 @@
 const assert = require("assert");
+const fs = require("fs");
+const path = require("path");
+const os = require("os");
 const { Store } = require("../src/store");
 const { NoteService } = require("../src/service");
 const { run } = require("../src/cli");
@@ -9,4 +12,47 @@ assert.strictEqual(svc.pending().length, 1);
 svc.complete(1);
 assert.strictEqual(svc.pending().length, 0);
 assert.strictEqual(run(["add", "via", "cli"], svc).text, "via cli");
+
+// tags: add / remove / no-duplicate / absent no-op
+svc.tag(1, "work");
+assert.deepStrictEqual(svc.store.get(1).tags, ["work"]);
+svc.tag(1, "work");
+assert.deepStrictEqual(svc.store.get(1).tags, ["work"]);
+svc.untag(1, "work");
+assert.deepStrictEqual(svc.store.get(1).tags, []);
+svc.untag(1, "nope");
+assert.deepStrictEqual(svc.store.get(1).tags, []);
+assert.throws(() => svc.tag(999, "x"), /not found/);
+
+// byTag + stats
+svc.tag(1, "work");
+svc.tag(2, "work");
+svc.tag(2, "urgent");
+assert.strictEqual(svc.byTag("work").length, 2);
+assert.strictEqual(svc.byTag("urgent").length, 1);
+assert.deepStrictEqual(svc.stats(), { work: 2, urgent: 1 });
+
+// save/load round-trips tags
+const tmp = path.join(os.tmpdir(), "notes-test-" + process.pid + ".json");
+svc.store.save(tmp);
+const loaded = Store.load(tmp);
+assert.deepStrictEqual(loaded.get(2).tags, ["work", "urgent"]);
+fs.unlinkSync(tmp);
+
+// older data without tags normalizes to []
+const legacy = path.join(os.tmpdir(), "notes-legacy-" + process.pid + ".json");
+fs.writeFileSync(legacy, JSON.stringify({ notes: [{ id: 1, text: "old", done: false }], seq: 1 }));
+const legacyStore = Store.load(legacy);
+assert.deepStrictEqual(legacyStore.get(1).tags, []);
+fs.unlinkSync(legacy);
+
+// CLI: tag / bytag / stats
+const csvc = new NoteService();
+csvc.create("a");
+csvc.create("b");
+run(["tag", "1", "home"], csvc);
+run(["tag", "2", "home"], csvc);
+assert.strictEqual(run(["bytag", "home"], csvc).length, 2);
+assert.deepStrictEqual(run(["stats"], csvc), { home: 2 });
+
 console.log("all tests passed");
