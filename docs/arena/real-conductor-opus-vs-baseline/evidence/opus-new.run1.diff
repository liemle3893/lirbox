diff --git a/src/cli.js b/src/cli.js
index afb0045..20b6c2d 100644
--- a/src/cli.js
+++ b/src/cli.js
@@ -4,6 +4,9 @@ function run(argv, svc) {
   const [cmd, ...rest] = argv;
   if (cmd === "add") return svc.create(rest.join(" "));
   if (cmd === "list") return svc.pending();
+  if (cmd === "tag") return svc.tag(Number(rest[0]), rest[1]);
+  if (cmd === "bytag") return svc.byTag(rest[0]);
+  if (cmd === "stats") return svc.stats();
   throw new Error("unknown command: " + cmd);
 }
 module.exports = { run };
diff --git a/src/service.js b/src/service.js
index c9c426d..0a1340e 100644
--- a/src/service.js
+++ b/src/service.js
@@ -5,5 +5,9 @@ class NoteService {
   create(text) { if (!text) throw new Error("text required"); return this.store.add(text); }
   complete(id) { const n = this.store.get(id); if (!n) throw new Error("not found"); n.done = true; return n; }
   pending() { return this.store.all().filter(n => !n.done); }
+  tag(id, tag) { const n = this.store.addTag(id, tag); if (!n) throw new Error("not found"); return n; }
+  untag(id, tag) { const n = this.store.removeTag(id, tag); if (!n) throw new Error("not found"); return n; }
+  byTag(tag) { return this.store.all().filter(n => (n.tags || []).includes(tag)); }
+  stats() { const s = {}; this.store.all().forEach(n => (n.tags || []).forEach(t => { s[t] = (s[t] || 0) + 1; })); return s; }
 }
 module.exports = { NoteService };
diff --git a/src/store.js b/src/store.js
index f0c794e..b1a3317 100644
--- a/src/store.js
+++ b/src/store.js
@@ -2,10 +2,12 @@
 const fs = require("fs");
 class Store {
   constructor() { this.notes = []; this.seq = 0; }
-  add(text) { const n = { id: ++this.seq, text, done: false }; this.notes.push(n); return n; }
+  add(text) { const n = { id: ++this.seq, text, done: false, tags: [] }; this.notes.push(n); return n; }
   get(id) { return this.notes.find(n => n.id === id) || null; }
   all() { return this.notes.slice(); }
+  addTag(id, tag) { const n = this.get(id); if (!n) return null; if (!n.tags.includes(tag)) n.tags.push(tag); return n; }
+  removeTag(id, tag) { const n = this.get(id); if (!n) return null; const i = n.tags.indexOf(tag); if (i !== -1) n.tags.splice(i, 1); return n; }
   save(path) { fs.writeFileSync(path, JSON.stringify({ notes: this.notes, seq: this.seq })); }
-  static load(path) { const s = new Store(); const d = JSON.parse(fs.readFileSync(path, "utf8")); s.notes = d.notes; s.seq = d.seq; return s; }
+  static load(path) { const s = new Store(); const d = JSON.parse(fs.readFileSync(path, "utf8")); s.notes = d.notes; s.seq = d.seq; s.notes.forEach(n => { n.tags = n.tags || []; }); return s; }
 }
 module.exports = { Store };
diff --git a/test/run.js b/test/run.js
index 949ca50..019f8b7 100644
--- a/test/run.js
+++ b/test/run.js
@@ -9,4 +9,89 @@ assert.strictEqual(svc.pending().length, 1);
 svc.complete(1);
 assert.strictEqual(svc.pending().length, 0);
 assert.strictEqual(run(["add", "via", "cli"], svc).text, "via cli");
+
+// --- Tagging + stats tests ---
+const fs = require("fs");
+const os = require("os");
+const path = require("path");
+
+// 1. Store addTag/removeTag
+{
+  const store = new Store();
+  const n = store.add("tagme");
+  store.addTag(n.id, "work");
+  assert.ok(n.tags.includes("work"), "tag added");
+  store.addTag(n.id, "work");
+  assert.strictEqual(n.tags.length, 1, "duplicate tag not added");
+  store.removeTag(n.id, "work");
+  assert.ok(!n.tags.includes("work"), "tag removed");
+  assert.strictEqual(n.tags.length, 0, "tags empty after remove");
+  // removeTag of absent tag is a no-op and does not throw
+  assert.doesNotThrow(() => store.removeTag(n.id, "nope"));
+  assert.strictEqual(n.tags.length, 0, "removing absent tag leaves tags unchanged");
+}
+
+// 2. Store save/load round-trip of tags
+{
+  const store = new Store();
+  const n1 = store.add("first");
+  const n2 = store.add("second");
+  store.addTag(n1.id, "work");
+  store.addTag(n1.id, "urgent");
+  store.addTag(n2.id, "home");
+  const tmp = path.join(os.tmpdir(), `notes-test-${process.pid}-${Date.now()}.json`);
+  try {
+    store.save(tmp);
+    const loaded = Store.load(tmp);
+    assert.deepStrictEqual(loaded.get(n1.id).tags, ["work", "urgent"], "n1 tags survive round-trip");
+    assert.deepStrictEqual(loaded.get(n2.id).tags, ["home"], "n2 tags survive round-trip");
+  } finally {
+    fs.rmSync(tmp, { force: true });
+  }
+}
+
+// 3. Service byTag
+{
+  const s = new NoteService();
+  const a2 = s.create("has work");
+  const b2 = s.create("no tags");
+  s.tag(a2.id, "work");
+  const results = s.byTag("work");
+  assert.strictEqual(results.length, 1, "one note carries the tag");
+  assert.strictEqual(results[0].id, a2.id, "correct note returned");
+  assert.ok(!s.byTag("work").some(n => n.id === b2.id), "untagged note not returned");
+}
+
+// 4. Service stats
+{
+  const s = new NoteService();
+  const n1 = s.create("one");
+  const n2 = s.create("two");
+  const n3 = s.create("three");
+  s.tag(n1.id, "work");
+  s.tag(n2.id, "work");
+  s.tag(n2.id, "urgent");
+  s.tag(n3.id, "home");
+  assert.deepStrictEqual(s.stats(), { work: 2, urgent: 1, home: 1 }, "stats counts correct");
+}
+
+// 5. Service tag/untag throw on unknown id
+{
+  const s = new NoteService();
+  assert.throws(() => s.tag(999, "work"), /not found/, "tag throws on unknown id");
+  assert.throws(() => s.untag(999, "work"), /not found/, "untag throws on unknown id");
+}
+
+// 6. CLI tag / bytag / stats
+{
+  const s = new NoteService();
+  const n = s.create("cli note");
+  const tagged = run(["tag", n.id, "work"], s);
+  assert.ok(tagged.tags.includes("work"), "cli tag applied");
+  const found = run(["bytag", "work"], s);
+  assert.strictEqual(found.length, 1, "cli bytag returns match");
+  assert.strictEqual(found[0].id, n.id, "cli bytag returns correct note");
+  assert.deepStrictEqual(run(["stats"], s), { work: 1 }, "cli stats returns counts");
+}
+
 console.log("all tests passed");
