// C4 model of the lirbox repo — a personal Claude Code plugin marketplace.
// Traced from README.md, CLAUDE.md, CONTRIBUTING.md, .claude-plugin/marketplace.json
// and plugins/lirbox/ (skills/, agents/). Source of truth: this file.

specification {
  element actor {
    style { shape person }
  }
  element system
  element external {
    style { color muted }
  }
  element container
  element component

  // design-lineage (code provenance), visually distinct from runtime edges
  relationship lineage {
    line dotted
    color muted
  }
}

model {
  dev = actor 'Developer' {
    description 'liemle3893 — installs the marketplace, invokes skills by describing tasks, reviews the PRs the loop skills open'
  }

  claude = external 'Claude Code' {
    technology 'CLI'
    description 'Host CLI: registers the marketplace, auto-discovers skills/agents from the plugin, triggers skills on their frontmatter descriptions, runs subagents and the Workflow tool'
  }

  dockerd = external 'Docker Daemon' {
    description 'Runs the pinned LikeC4 toolchain image in a throwaway container for the c4-model skill; nothing installed on the host'
  }

  github = external 'GitHub' {
    description 'Hosts the marketplace repo (liemle3893/lirbox); receives the review PRs opened by prospector/whetstone (never auto-merged)'
  }

  lirbox = system 'lirbox Marketplace' {
    description 'Personal Claude Code plugin marketplace: one plugin ("lirbox") holding skills and agents'

    artifactSkills = container 'HTML-Artifact Skills' {
      technology 'SKILL.md + scripts/ + references/ + assets/'
      description 'Family 1: each skill emits one self-contained HTML file'

      prWriteup = component 'pr-writeup' {
        description 'Turns a pull request into a reviewer-facing HTML write-up (TL;DR, motivation, file-by-file tour, test plan)'
      }
      planDeck = component 'plan-deck' {
        description 'Turns a spec/task into an HTML implementation plan (milestone timeline, data-flow, risks, open questions)'
      }
      codewalk = component 'codewalk' {
        description 'Traces ONE path through a real codebase into an HTML walkthrough with verified file:line steps'
      }
      flowchart = component 'flowchart' {
        technology 'Mermaid'
        description 'Branching process as an interactive HTML flowchart; ships headless assets/validate.mjs that catches Mermaid label-escaping bugs'
      }
      componentDiagram = component 'component-diagram' {
        technology 'Mermaid'
        description 'Static structure as an interactive HTML component diagram (subgraph boundaries, typed dependency edges)'
      }
      sequenceDiagram = component 'sequence-diagram' {
        technology 'Mermaid'
        description 'Time-ordered interaction as an interactive HTML sequence diagram with a clickable numbered step list'
      }
      c4model = component 'c4-model' {
        technology 'LikeC4'
        description 'One .c4 source built into a single offline-viewable interactive HTML page (landscape → container → component drill-down)'
      }
      planCheck = component 'plan-check' {
        description 'Pressure-tests a plan/runbook and emits an HTML verification report with a GO / GO-WITH-CONDITIONS / NO-GO verdict'
      }
    }

    loopSkills = container 'Orchestration / Loop Skills' {
      technology 'deterministic JS conductor + worker subagents'
      description 'Family 2: one shared backbone — a pure-JS conductor script (generated by scaffold-*.cjs, never hand-edited) drives full-tool worker subagents; all side effects live in the workers'

      conductor = component 'conductor' {
        technology 'scaffold-workflow.cjs'
        description 'Durable, crash/restart-resumable multi-subagent Workflow runs: on-disk JSON state, worktree isolation, opt-in enforcement gates, cost report; leaves a wf/<name> branch; Writeup phase promotes delivery artifacts into docs/changes/'
      }
      prospector = component 'prospector' {
        technology 'scaffold-optimize.cjs'
        description 'Sequential keep-or-discard hill-climb of ONE surface against an auto-proposed numeric metric + hard correctness gate, on a per-run opt/<goal>-<ts> branch'
      }
      whetstone = component 'whetstone' {
        technology 'scaffold-improve.cjs'
        description 'Overnight eval-gated skill improver: grinds the feedback/<skill>.jsonl backlog through a deterministic floor + per-item frozen acceptance check, on a per-run improve/<skill>-<ts> branch'
      }

      prospector -[lineage]-> conductor 'reuses durable resumable backbone'
      whetstone -[lineage]-> prospector 'forks the two-layer loop, swaps scalar hill-climb for binary GREEN gate'
    }

    metaSkills = container 'Interactive & Meta Skills' {
      description 'Skills that emit no HTML artifact: a tutoring loop and a deterministic skill linter'

      deepUnderstanding = component 'deep-understanding' {
        description 'Interactive tutor: assesses, fills gaps, and quizzes the human until mastery of a PR/change/subsystem is verified'
      }
      skillLint = component 'skill-lint' {
        description 'Deterministic analyzer of the SKILL.md files themselves: word budget, XML tag balance, weak triggers, oversized references; reports, never edits'
      }
    }

    agents = container 'Enforcement-Gate Agents' {
      technology 'agents/*.md (frontmatter + system prompt)'
      description 'Generic subagents — the default enforcement gates for conductor, also usable standalone'

      testWriter = component 'lirbox-test-writer' {
        description 'Test-first (RED): writes failing tryve-E2E/unit tests from acceptance criteria before implementation'
      }
      tryveEnhancer = component 'lirbox-tryve-enhancer' {
        description 'Hardens coverage from the diff: error paths, boundaries, auth, concurrency'
      }
      codeReviewer = component 'lirbox-code-reviewer' {
        description 'Reviews changed code and fixes Critical/High findings, keeping the build green'
      }
      docsWriter = component 'lirbox-docs-writer' {
        description 'Writes a concise implementation summary into docs/changes/ from the diff + goal + notes'
      }
      webVerifier = component 'lirbox-web-verifier' {
        technology 'Playwright → browser-MCP → OS-script'
        description 'Web half of the frontend gate: Playwright E2E specs + per-viewport screenshot/console evidence'
      }
      mobileVerifier = component 'lirbox-mobile-verifier' {
        technology 'Maestro / Appium / simctl / adb'
        description 'Mobile half of the frontend gate: detects RN/Flutter/native, writes E2E flows, falls back to raw evidence capture'
      }
    }
  }

  dev -> claude 'describes tasks to' 'CLI'
  dev -> github 'reviews and merges the loop-skill PRs on'
  claude -> lirbox 'registers marketplace, discovers plugin + skills from .claude-plugin/marketplace.json' '/plugin marketplace add'
  claude -> lirbox.artifactSkills 'invokes on description trigger'
  claude -> lirbox.loopSkills 'invokes on description trigger'
  claude -> lirbox.metaSkills 'invokes on description trigger'
  claude -> lirbox.agents 'dispatches as subagents'

  lirbox.loopSkills.conductor -> claude 'drives the Workflow tool (deterministic JS conductor + subagent fan-out)'
  lirbox.loopSkills.prospector -> claude 'drives the Workflow tool'
  lirbox.loopSkills.whetstone -> claude 'drives the Workflow tool'
  lirbox.loopSkills.conductor -> lirbox.agents 'dispatches as default enforcement gates'
  lirbox.loopSkills.prospector -> github 'opens optimization PR for review, never merges' 'gh CLI'
  lirbox.loopSkills.whetstone -> github 'opens improvement PR for review, never merges' 'gh CLI'
  lirbox.artifactSkills.c4model -> dockerd 'runs LikeC4 toolchain in throwaway container' 'ghcr.io/likec4/likec4:1.58.0'
  lirbox.metaSkills.skillLint -> lirbox.artifactSkills 'audits SKILL.md files of'
  lirbox.metaSkills.skillLint -> lirbox.loopSkills 'audits SKILL.md files of'
  lirbox.metaSkills.skillLint -> lirbox.metaSkills.deepUnderstanding 'audits SKILL.md of (lints every skill, itself included)'
  lirbox.metaSkills.deepUnderstanding -> dev 'quizzes until mastery is verified'
}

views {
  view index {
    title 'lirbox — System Landscape'
    include *
  }

  view of lirbox {
    title 'lirbox Marketplace — Containers'
    include *, dev, claude, dockerd, github
  }

  view of lirbox.artifactSkills {
    title 'HTML-Artifact Skills — Components'
    include *, claude, dockerd
  }

  view of lirbox.loopSkills {
    title 'Orchestration / Loop Skills — Components'
    include *, claude, github, lirbox.agents
  }

  view of lirbox.metaSkills {
    title 'Interactive & Meta Skills — Components'
    include *, dev, lirbox.artifactSkills, lirbox.loopSkills
  }

  view of lirbox.agents {
    title 'Enforcement-Gate Agents — Components'
    include *, claude, lirbox.loopSkills.conductor
  }
}
