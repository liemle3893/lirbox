# OS / editor junk
.DS_Store
*.swp

# Local design docs (brainstorming specs / implementation plans) — never tracked or published
docs/superpowers/

# Runtime artifacts from the pr-writeup skill (if ever run inside the repo)
.pr-writeup/
*-writeup.html

# Conductor / prospector / whetstone / arena runtime state (local; the resume key lives here, not tracked)
.workflows/
.optimize/
.improve/
.arena/

# Build-time scratch left by conductor/prospector workers (delivered only via docs/changes, else dropped)
implementation-notes/

# Git worktrees created by conductor/prospector/whetstone
.worktrees/

# Generated single-file HTML artifacts (flowchart / codewalk / plan-deck / component / sequence skills)
*-flowchart.html
*-codewalk.html
*-plan-deck.html
*-component.html
*-sequence.html

# EXCEPTION: conductor's Writeup phase PROMOTES delivery artifacts into docs/changes/<name>/
# (writeup.html, design.html, notes/*.html, summary.md) — these ARE tracked, they ride the PR.
# Must come AFTER the filename-globs above so it re-includes anything they would catch.
!docs/changes/
!docs/changes/**

# EXCEPTION: arena's Finalize phase PROMOTES the leaderboard into docs/arena/<name>/
# (leaderboard.html, report.md) — tracked so the finalize PR carries a diff.
!docs/arena/
!docs/arena/**
